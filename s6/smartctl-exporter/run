#!/usr/bin/env sh
# smartctl_exporter auto-discovers drives. On Dell hosts with PERC
# RAID, `smartctl --scan` returns both the real drives at
# /dev/bus/0 -d megaraid,N AND duplicate /dev/sd[a-z] entries that
# always fail to open ("please try adding '-d megaraid,N'"). Each
# failed open takes ~5s, blocking the poll cycle long enough that
# Prometheus scrapes time out.
#
# Detect megaraid passthrough and exclude the bogus /dev/sd[a-z]
# entries on those hosts. On plain SATA hosts (Unraid etc.) the
# /dev/sd[a-z] entries are the real drives — no exclusion applied.
if smartctl --scan 2>/dev/null | grep -q 'megaraid'; then
  echo "[smartctl-exporter] megaraid passthrough detected — excluding /dev/sd[a-z]+ phantoms"
  exec /usr/local/bin/smartctl_exporter \
    --web.listen-address=:9633 \
    --smartctl.device-exclude='^/dev/sd[a-z]+$'
fi
exec /usr/local/bin/smartctl_exporter --web.listen-address=:9633
