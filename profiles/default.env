# Default profile — sourced AFTER any model-specific profile so unset vars
# get sensible fallbacks. Values use `:=` so they only apply when nothing
# else set them. Precedence (highest first): container env (compose) →
# model profile (e.g. r730xd.env) → this default.env.
#
# These are conservative starter values. The controller runs three
# independent PIDs (CPU, passive GPU, HDD) each with its own target,
# deadband, emergency, and approach window — tune the class you care
# about without touching the others. The fan-system gains (P, D, drift,
# alpha) are shared across all classes.

: "${INTERVAL:=15}"            # seconds between checks. 15s gives 2x
                               # the resolution to react to fast spikes
                               # (P4 was seen jumping +14°C in 30s; at
                               # 15s the controller catches at +7°C
                               # which is well within the setpoint
                               # loop's response zone). Normally no
                               # change vs 30s — same drift, same
                               # outputs; only matters in transients.

# --- CPU thresholds (one of the three PIDs) ---
: "${CPU_TARGET:=70}"          # °C — target max CPU die temp.
: "${CPU_DEADBAND:=3}"         # ±°C happy zone for CPU
: "${CPU_EMERGENCY:=80}"       # °C — instant 100% fans. 5-15°C below
                               # Xeon E5-2600 v3/v4 TJ (85-95°C). Real
                               # CPUs in this fleet idle 45-58°C under
                               # qwen load, so 80 means actual trouble.
: "${CPU_APPROACH_WINDOW:=10}" # °C — proximity floor starts ramping at
                               # CPU_EMERGENCY - this many °C. At the
                               # outer edge the floor is MIN_FAN; at
                               # EMERGENCY it's MAX_FAN. Wider window =
                               # earlier (quieter) start of ramp.

# --- Passive GPU thresholds (one of the three PIDs) ---
#
# Set against the family working-temp envelope of passive datacenter
# cards (Tesla P4/T4/M40/P40/A2/L4/A10). All idle 30-50°C in a 2U
# chassis; all settle 75-87°C under sustained 80%+ utilization with
# chassis fans high-but-not-redlined. Slowdown thresholds cluster at
# 87-92°C across the family; throttle-to-shutdown 95°C.
#
# History (commit 59c78ea / earlier): TARGET=72, EMERGENCY=85,
# WINDOW=10. That target was *physically unachievable* under sustained
# load — a P4 at 91% util / 75W stable at 82°C with 19°C inlet air
# even with chassis fans at 100% (verified by live trace 2026-05-15).
# The P+D controller had constant positive error and saturated fans
# to MAX_FAN trying to chase a ghost. ~17500 RPM for noise gain of 0
# (same equilibrium temperature, much more sound).
#
# New tune (this commit):
#  TARGET=83          — median working temp across the family. Idle
#                       cards sit below it (PID drifts to MIN_FAN);
#                       hot cards sit at-or-above (PID +small step).
#  DEADBAND=2         — narrow happy zone (81-85°C), don't react to
#                       1°C thermal noise inside the working band.
#  EMERGENCY=90       — family slowdown floor. Older 85 was 2-7°C
#                       below the actual slowdown of the cards we
#                       might run; would trip emergency on normal
#                       sustained load.
#  APPROACH_WINDOW=5  — proximity floor engages at 85°C (= emergency
#                       - window), saturates at 90°C. Tight ramp:
#                       gives PID 2°C of room (deadband upper edge to
#                       PF start), then PF takes over as the safety
#                       mechanism.
: "${GPU_TARGET:=83}"
: "${GPU_DEADBAND:=2}"
: "${GPU_EMERGENCY:=90}"
: "${GPU_APPROACH_WINDOW:=5}"

# --- Active GPU thresholds (drive assist + own emergency, NOT a PID) ---
# Active cards (own fan, e.g. A5500) tolerate higher temps and can't be
# cooled by chassis fans directly — chassis only helps by lowering
# intake-air temp. Separate from passive thresholds so a hot A5500
# under inference load doesn't trigger emergency for normal operation.
: "${ACTIVE_GPU_TARGET:=78}"   # °C — threshold at which active GPUs
                               # start lifting chassis floor for
                               # intake-air assist. A5500 normally
                               # operates 75-85°C under qwen load; 78
                               # means "starting to work hard, give
                               # the chassis some lift."
: "${ACTIVE_GPU_EMERGENCY:=88}"# °C — instant 100% if any active GPU
                               # hits this. A5500 TJ-throttle is ~93°C;
                               # 88 leaves 5°C buffer. Higher than
                               # passive (85) because the card's own
                               # fan is doing the real cooling.
: "${ACTIVE_GPU_APPROACH_WINDOW:=10}" # °C — see CPU_APPROACH_WINDOW.

# --- HDD thresholds (one of the three PIDs) ---
# Drives are read via smartctl --scan + smartctl -A -n standby. HDD_AWARE
# (env) controls auto/true/false detection. With auto, HDDs are silently
# skipped if smartctl is unavailable or finds no drives.
#
# Defaults sit firmly inside the research consensus:
#   - Google FAST 2007 (100K+ drives): optimal failure-rate band 37-46°C.
#   - U. Virginia / Microsoft 2013 (10K drives): ~4%/yr at 27°C → ~12%/yr
#     at 50°C → ~14%/yr at 55°C. Recommends "don't steadily exceed 47°C."
#   - Enterprise drive specs (Seagate Exos, WD RE): 5-55°C / 5-60°C max.
# TARGET sits in the center of Google's optimal band; EMERGENCY is at
# UVa's elevated-failure inflection AND below most enterprise max specs;
# WINDOW=5 keeps the ramp out of normal operating range (typical drives
# run 30-43°C, so ramp starts at 45°C — exactly the "left the safe zone"
# point per UVa).
: "${HDD_TARGET:=40}"
: "${HDD_DEADBAND:=3}"
: "${HDD_EMERGENCY:=50}"
: "${HDD_APPROACH_WINDOW:=5}"  # narrower than CPU/GPU — drives operate
                               # naturally close to their emergency
                               # threshold, so a 10°C window would have
                               # the proximity floor active during
                               # normal operation.
: "${HDD_READ_INTERVAL:=60}"   # seconds between smartctl polls. Drives
                               # respond slowly to airflow changes;
                               # 60s = 4 main cycles. Reduces smartctl
                               # traffic to PERC and avoids any chance
                               # of waking spun-down drives more than
                               # necessary (we use -n standby anyway).

# --- SSD thresholds (one of the four PIDs) ---
# Separate from HDDs because solid-state drives operate happily 10-15°C
# warmer than spinning disks by design (no moving parts, plastic/silicon
# tolerates higher temps than aluminum platters). Pre-split, the HDD
# class took max() across all drive types — an SSD's normal 42-44°C
# idle would drag HDD_max above target=40 and constantly push fans up
# even when the spinning drives were comfortably cool. Splitting them
# gives each class its own threshold band:
#
# Consumer/datacenter SSD specs: operating 0-70°C, throttle 80-85°C,
# absolute max ~95°C. The 50°C target with ±5°C deadband sits in the
# safe middle. EMERGENCY at 65°C is well below throttle, leaving a
# comfortable buffer.
: "${SSD_TARGET:=50}"
: "${SSD_DEADBAND:=5}"
: "${SSD_EMERGENCY:=65}"
: "${SSD_APPROACH_WINDOW:=8}" # ramp starts at 57°C — between deadband
                               # upper edge (55) and emergency (65), so
                               # the proximity floor lifts as the SSD
                               # leaves its happy zone, not while it's
                               # still inside it.

: "${MIN_FAN:=20}"             # % — chassis acoustic floor
: "${MAX_FAN:=100}"            # % — ceiling
: "${FAN_GAIN:=0.5}"           # P-gain: % fan per °C error from target.
                               # Smaller = smaller per-cycle changes
                               # = less audible. Slower convergence, but
                               # EMERGENCY catches genuine transients.
                               # Tune up (1.0) for faster response,
                               # down (0.3) for even smoother. Shared
                               # across all three PIDs — split per-class
                               # later if any class wants its own gain.
: "${DERIVATIVE_GAIN:=1.0}"    # D-gain: % fan per °C/cycle rate-of-
                               # change for each class's PID. "Catch
                               # the wave": a fast rising temp gets a
                               # bigger fan response than a slow drift,
                               # even at the same absolute error. Also
                               # symmetric — falling temps ease off
                               # fans even if still above target.
                               # 1.0 → a +5°C/cycle climb adds +5% fan
                               # on top of the proportional step.
                               # Higher = more anticipatory + jumpier
                               # response to sensor noise; lower =
                               # smoother but slower wave-catching.
: "${ASSIST_GAIN:=3}"          # % chassis floor lift per °C that an
                               # active GPU exceeds ACTIVE_GPU_TARGET.
                               # 3 → A5500 at 82°C lifts floor to ~22%,
                               # at 85°C ~31%, at 88°C (emergency) caps
                               # before triggering. Higher gain = more
                               # aggressive assist + more noise. The
                               # gain interacts with ACTIVE_GPU_TARGET:
                               # raise the target to defer assist,
                               # raise the gain to ramp it harder once
                               # triggered.
: "${DEADBAND_DRIFT_RATE:=3}"  # % per cycle each PID's candidate drifts
                               # toward MIN_FAN when its class is in
                               # deadband + at-or-below target. Each PID
                               # drifts independently; max() across all
                               # 3 candidates is what binds. Prevents
                               # current_speed from getting locked at a
                               # stale value (e.g., 100% from a prior
                               # spike) while temps are in the happy zone.
                               #
                               # History:
                               #  2 (original): too slow, recovery from
                               #    a 70% spike took ~14 min.
                               #  4 (tried): overshot on docker-1 — fans
                               #    dropped to MIN_FAN, passive P4 die
                               #    climbed +20°C to 79°C (proximity floor
                               #    saved it but uncomfortably close to
                               #    85°C emergency). Drift was faster than
                               #    PID step could catch.
                               #  3 (current): compromise. 50% faster
                               #    than original 2; cycle delta exactly
                               #    matches the PID step a borderline-
                               #    target class generates (error≈deadband
                               #    × gain 0.5 ≈ 1.5 → rounds to ±2 step),
                               #    so once fans are dropping, the next
                               #    in-deadband class doesn't have a worse
                               #    binding rate than an outside-deadband
                               #    one. Stable on hosts with passive
                               #    GPUs in the chassis.
: "${ADAPT_ALPHA:=0.001}"      # EWMA smoothing — ~24-48 hr base adaptation

# --- IPMI temperature sensor mapping (vmagent metric_relabel) ---
# Per-chassis IPMI sensor name + FreeIPMI record ID, mapped to a stable
# `class` label so the Grafana dashboard can query {class="cpu1"} etc.
# regardless of chassis. ipmi_exporter uses FreeIPMI's record ID (NOT
# the BMC raw id shown by `ipmitool sdr`); query
# `ipmi_temperature_celsius{host=...}` to see what your chassis reports
# before filling these in.
#
# A blank value means "this chassis doesn't expose that class via IPMI"
# — coretemp via node_hwmon_temp_celsius covers CPU temps on every
# Linux host as a universal fallback, so it's fine to leave CPU sensor
# vars blank on older boxes (e.g. R410) that don't expose per-socket
# IPMI temps.
: "${SENSOR_CPU1_NAME:=}"
: "${SENSOR_CPU1_ID:=}"
: "${SENSOR_CPU2_NAME:=}"
: "${SENSOR_CPU2_ID:=}"
: "${SENSOR_INLET_NAME:=}"
: "${SENSOR_INLET_ID:=}"
: "${SENSOR_EXHAUST_NAME:=}"
: "${SENSOR_EXHAUST_ID:=}"
