# Dell XC730xd-12 profile.
#
# XC = Dell's Nutanix OEM rebadge of the R730xd. Same chassis, same
# 60mm hot-swap fans, same iDRAC8 BMC behavior. Use R730xd-equivalent
# tuning (MIN_FAN=10 — BMC clamps lower values to a safety RPM, no
# fan-stall risk).
#
# product_name "Dell XC730xd-12" → detect_model output "dell_xc730xd_12"
# (the current detection doesn't strip the "Dell " prefix; this file
# matches what's actually produced).

: "${MIN_FAN:=10}"             # BMC's hard floor — going lower = same RPM

# Per-server HDD tuning — measured on this box (2026-06).
#
# This 12-bay cage + 60mm fans give the array a ~4.5 min thermal dead time
# with a natural min-fan rest of ~45-46°C. On a plant whose dead time ≈ its
# time constant, servoing tightly to the 40°C shipped default is twitchy and
# slow (it crawls toward 40 over ~25 min and rides ~45°C the whole way). So we
# target the measured STABLE point instead: 43°C holds rock-steady at a modest
# steady fan (~25%) with no hunt — cooler than the ~46°C this array drifted to
# before, comfortably under the 50°C emergency.
#
# Tight deadband is required for the target to bite: the band's top edge
# (target+deadband) must sit BELOW the ~45°C natural rest, or the drive just
# parks at the band edge and the fan never engages. 43±1 → band 42-44.
: "${HDD_TARGET:=43}"
: "${HDD_DEADBAND:=1}"

# IPMI temperature sensors on the XC730xd-12's iDRAC8. Identical
# layout to r730xd / r730 (same BMC firmware family). Two CPU sensors
# share the name "Temp", distinguished by FreeIPMI record id 26/27.
# Inlet and Exhaust have unique names.
: "${SENSOR_CPU1_NAME:=Temp}"
: "${SENSOR_CPU1_ID:=26}"
: "${SENSOR_CPU2_NAME:=Temp}"
: "${SENSOR_CPU2_ID:=27}"
: "${SENSOR_INLET_NAME:=Inlet Temp}"
: "${SENSOR_EXHAUST_NAME:=Exhaust Temp}"
