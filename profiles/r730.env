# PowerEdge R730 (gen 13, 2U dual-socket).
#
# UNTESTED but very high-confidence — same chassis family as R730xd
# (probed). The "xd" suffix only adds the extended drive bay; the BMC,
# fans, and thermal envelope are identical. Use R730xd's MIN_FAN=10.
#
# If you observe fan stall or BMC errors at MIN_FAN=10, bump to 20.

: "${MIN_FAN:=10}"

# IPMI temperature sensors on R730's iDRAC8 — identical layout to R730xd
# (same BMC firmware family across the gen-13 PowerEdge line). Two CPU
# sensors share the name "Temp", distinguished by FreeIPMI record id
# 26/27. Inlet/Exhaust have unique names.
: "${SENSOR_CPU1_NAME:=Temp}"
: "${SENSOR_CPU1_ID:=26}"
: "${SENSOR_CPU2_NAME:=Temp}"
: "${SENSOR_CPU2_ID:=27}"
: "${SENSOR_INLET_NAME:=Inlet Temp}"
: "${SENSOR_EXHAUST_NAME:=Exhaust Temp}"
